{
  "name": "cbcter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "prebuild": "node scripts/stage-ort.mjs",
    "pretest:e2e": "node scripts/build_e2e_sample.mjs",
    "stage:ort": "node scripts/stage-ort.mjs",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "pretest:e2e:update": "node scripts/build_e2e_sample.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "sample:build": "python3 scripts/build_sample_volume.py \"$CBCTER_SAMPLE_DICOM_DIR\" public/sample-cbct",
    "sample:link-dicom": "python3 scripts/link_sample_dicom.py",
    "segment:sample": "python3 scripts/run_tooth_segmentation.py --dicom-dir \"$CBCTER_SAMPLE_DICOM_DIR\" --model models/model-toothcrops-CBCT-normalize_best.pth --output-dir outputs/sample-segmentation --roi 170 170 130 314 314 274",
    "segment:slicer-roi": "python3 scripts/run_tooth_segmentation.py --dicom-dir \"$CBCTER_SAMPLE_DICOM_DIR\" --model models/model-toothcrops-CBCT-normalize_best.pth --output-dir outputs/slicer-exact-roi --roi 88 53 315 224 145 407 --slicer-exact --export-stl",
    "segment:test-slicer-roi": "python3 scripts/test_slicer_roi_shape.py --dicom-dir \"$CBCTER_SAMPLE_DICOM_DIR\" --model models/model-toothcrops-CBCT-normalize_best.pth --output-dir outputs/slicer-roi-shape-test --roi 122 72 288 218 144 372 --export-stl",
    "segment:arch": "python3 scripts/run_tooth_segmentation.py --dicom-dir \"$CBCTER_SAMPLE_DICOM_DIR\" --model models/model-toothcrops-CBCT-normalize_best.pth --output-dir outputs/sample-arch-segmentation --arch-rois",
    "segment:auto": "python3 scripts/run_tooth_segmentation.py --dicom-dir \"$CBCTER_SAMPLE_DICOM_DIR\" --model models/model-toothcrops-CBCT-normalize_best.pth --output-dir outputs/sample-auto-segmentation --auto-rois --export-stl",
    "segment:hybrid": "python3 scripts/run_tooth_segmentation.py --dicom-dir \"$CBCTER_SAMPLE_DICOM_DIR\" --model models/model-toothcrops-CBCT-normalize_best.pth --output-dir outputs/sample-hybrid-segmentation --hybrid-rois --max-rois 32 --export-stl",
    "segment:watershed": "python3 scripts/run_watershed_tooth_separation.py",
    "segment:curate": "python3 scripts/curate_tooth_separation.py",
    "segment:validate": "python3 scripts/validate_tooth_separation.py",
    "segment:audit-shapes": "python3 scripts/audit_tooth_shapes.py",
    "segment:pipeline": "python3 scripts/build_tooth_separation_pipeline.py",
    "segment:export-onnx": "python3 scripts/export_tooth_onnx.py",
    "segment:validate-onnx": "python3 scripts/validate_onnx_pipeline.py"
  },
  "dependencies": {
    "@types/lodash": "^4.17.24",
    "clsx": "^2.1.1",
    "convex": "^1.39.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "fflate": "^0.8.2",
    "i18next": "^26.0.3",
    "lodash": "^4.17.23",
    "lucide-react": "^1.16.0",
    "onnxruntime-web": "^1.26.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
